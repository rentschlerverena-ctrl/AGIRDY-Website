---
/* src/components/Product.astro */
const { productData } = Astro.props;

if (!productData) {
  console.error("Product: Keine Daten empfangen!");
}
---

<section class="product-section" id="product">
  <div class="container">
    
    <div class="title-row">
      <h2 class="section-title">{productData?.title || "PRODUCT"}</h2>
      <p class="section-title-sub">{productData?.subtitle}</p>
    </div>

    <div class="slider-wrapper">
      <div class="slider-container" id="productSlider">
        
        <div class="card product-card image-card">
          <div class="feature-id">CORE</div>
          
          <div class="card-content">
            <div class="image-inner-frame">
              <img src="/product-brain.jpg" alt="Agirdy Core Visual" class="main-img" />
              <div class="vignette-overlay"></div>
            </div>
            
            <div class="card-header">
              <h3 class="card-title">{productData?.imageCardTitle}</h3>
              <p class="card-subtitle">{productData?.imageCardSubtitle}</p>
            </div>

            <div class="card-body">
              <p class="card-desc">{productData?.imageCardDesc}</p>
            </div>
          </div>
          <div class="image-glow"></div>
        </div>

        <div class="features-scroll-track">
          {productData?.features?.map((item) => (
            <div class="card product-card feature-card">
              <div class="feature-id">{item.id}</div>
              
              <div class="card-content">
                <div class="card-header">
                  <h3 class="card-title">{item.title}</h3>
                </div>
                
                <div class="card-body">
                  <p class="card-desc">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="slider-vignette-right"></div>

      <div class="slider-nav">
        <button class="nav-btn" id="prevBtn" aria-label="Zurück">
          <svg viewBox="0 0 24 24" width="28" height="28"><path fill="var(--accent)" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <button class="nav-btn" id="nextBtn" aria-label="Weiter">
          <svg viewBox="0 0 24 24" width="28" height="28"><path fill="var(--accent)" d="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12z"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('productSlider');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');

  if (slider && prevBtn && nextBtn) {
    const handleScroll = (direction) => {
      const card = slider.querySelector('.feature-card');
      if (!card) return;

      // Breite einer Karte + Gap (30px)
      const scrollAmount = card.getBoundingClientRect().width + 30;

      // 1. Snapping kurz ausschalten für flüssige JS-Animation
      slider.style.scrollSnapType = 'none';

      // 2. Scrollen
      slider.scrollBy({
        left: direction === 'next' ? scrollAmount : -scrollAmount,
        behavior: 'smooth'
      });

      // 3. Snapping nach der Animation wieder aktivieren
      // Das verhindert, dass die Karte "steckenbleibt"
      let isScrolling;
      slider.addEventListener('scroll', () => {
        window.clearTimeout(isScrolling);
        isScrolling = setTimeout(() => {
          slider.style.scrollSnapType = 'x mandatory';
        }, 150); // Sobald der Scrollvorgang stoppt
      }, { once: true });
    };

    nextBtn.addEventListener('click', () => handleScroll('next'));
    prevBtn.addEventListener('click', () => handleScroll('prev'));
  }
</script>

<style>
  /* Dein Design bleibt exakt wie im Ursprung */
  .product-section {
    position: relative;
    padding: 120px 0;
    background: transparent;
    width: 100%;
    overflow: hidden;
    z-index: 5;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
  }

  .slider-wrapper {
    position: relative;
    width: 100%;
    margin-top: -50px;
  }

  .slider-vignette-right {
    position: absolute;
    top: 0;
    right: -2px;
    height: calc(100% - 80px);
    width: 150px;
    background: linear-gradient(to left, var(--bg) 0%, transparent 100%);
    z-index: 12;
    pointer-events: none;
  }

  .slider-container {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 20px 0 40px 0;
    -ms-overflow-style: none;
    cursor: grab;
    align-items: stretch; 
    position: relative;
    z-index: 5;
  }

  .slider-container::-webkit-scrollbar {
    display: none;
  }

  .product-card {
    scroll-snap-align: start;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
  }

  .feature-card {
    flex: 0 0 420px; 
    min-height: 520px; 
    height: auto;
    margin: auto 0; 
  }

  .image-card {
    flex: 0 0 500px;
    min-height: 620px;
    height: auto;
    position: sticky;
    left: 0;
    top: 0;
    z-index: 10;
    background: rgba(10, 15, 21, 0.98);
    backdrop-filter: blur(25px);
    box-shadow: 20px 0 50px rgba(0,0,0,0.5);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
  }

  .features-scroll-track {
    display: flex;
    gap: 30px;
    align-items: stretch; 
  }

  .image-inner-frame {
    position: relative;
    width: 100%;
    height: 220px;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
  }

  .vignette-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 15, 20, 0.8) 0%, transparent 100%);
  }

  .feature-id {
    font-family: 'Bebas Neue', sans-serif;
    color: var(--accent);
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    z-index: 2;
  }

  .card-header {
    margin-bottom: 1.5rem;
    z-index: 2;
  }

  .card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.8rem;
    line-height: 1.1;
    margin: 0;
    text-transform: uppercase;
    color: var(--text);
  }

  .card-subtitle {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--accent);
    margin-top: 0.5rem;
    letter-spacing: 2px;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1; 
  }

  .card-body {
    margin-top: 1rem;
    z-index: 2;
  }

  .card-desc {
    font-family: 'Lato', sans-serif;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  .image-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(173, 255, 47, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  .slider-nav {
    display: flex;
    gap: 15px;
    position: absolute;
    left: 240px; 
    bottom: 40px; 
    width: 420px; 
    justify-content: flex-end; 
    z-index: 20;
  }

  .nav-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--accent); 
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
  }

  .nav-btn svg path { fill: var(--accent); }

  .nav-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    transform: scale(1.05);
  }
  
  .nav-btn:hover svg path { fill: #000; }

  @media (max-width: 1024px) {
    .slider-vignette-right { display: none; }
    .image-card { position: relative; flex: 0 0 100%; box-shadow: none; border-right: none; }
    .feature-card { flex: 0 0 85%; }
  }

  @media (max-width: 768px) {
    .slider-container { flex-direction: column; overflow-x: visible; scroll-snap-type: none; gap: 20px; }
    .features-scroll-track { flex-direction: column; gap: 20px; width: 100%; }
    .image-card, .feature-card { flex: 0 0 auto; width: 100%; min-height: auto; scroll-snap-align: none; }
    .slider-nav { display: none; }
    .product-card { padding: 2rem; }
    .card-title { font-size: 2.2rem; }
  }
</style>