---
/* src/pages/en/privacy.astro */
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import privacyData from '/src/data/en/privacy.json'; 

const lang = 'en';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{privacyData.pageTitle} | AGIRDY</title>
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bebas+Neue&family=Lato:wght@400;700;900&display=swap" rel="stylesheet">
  
  <style>
    /* Exakter Stil aus deinem Original */
    :root { --accent: #adff2f; --bg: #0a0f14; --text: #ffffff; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body { 
      background-color: var(--bg); 
      color: var(--text); 
      font-family: 'Lato', sans-serif; 
      line-height: 1.6; 
    }

    .legal-page { 
      padding: 180px 0 100px; 
      min-height: 100vh; 
    }

    .legal-container { 
      max-width: 900px; 
      margin: 0 auto; 
      padding: 0 5%; 
    }

    .archivo-title { 
      font-family: 'Archivo Black', sans-serif; 
      font-size: clamp(2.5rem, 8vw, 4rem); 
      margin-bottom: 10px; 
      text-transform: uppercase; 
    }
    
    .dot { color: var(--accent); }
    
    .accent-line { 
      width: 80px; 
      height: 4px; 
      background: var(--accent); 
      margin-bottom: 60px; 
    }

    .legal-block { margin-bottom: 50px; }

    .legal-block h2 { 
      font-family: 'Bebas Neue', sans-serif; 
      font-size: 2.2rem; 
      margin-bottom: 20px; 
      border-left: 3px solid var(--accent); 
      padding-left: 15px; 
      letter-spacing: 1px; 
    }
    
    .legal-block h3 { 
      font-family: 'Bebas Neue', sans-serif; 
      font-size: 1.5rem; 
      margin: 25px 0 10px; 
      color: var(--accent); 
    }
    
    .legal-block p { 
      color: rgba(255, 255, 255, 0.7); 
      font-size: 1.05rem; 
      margin-bottom: 15px; 
    }
    
    .legal-block a { 
      color: var(--accent); 
      text-decoration: none; 
      border-bottom: 1px solid transparent; 
      transition: 0.3s; 
    }
    
    .legal-block a:hover { border-bottom: 1px solid var(--accent); }
    
    strong { color: #fff; }
  </style>
</head>

<body>
  <Navbar lang={lang} />

  <main class="legal-page">
    <div class="legal-container">
      <h1 class="archivo-title">Privacy<wbr/>Policy<span class="dot">.</span></h1>
      <div class="accent-line"></div>
      
      {privacyData.sections.map((section) => (
        <div class="legal-block">
          <h2>{section.number}. {section.title}</h2>
          
          {section.blocks.map((block) => (
            <>
              <h3>{block.subtitle}</h3>
              <p set:html={block.content}></p>
            </>
          ))}
        </div>
      ))}
    </div>
  </main>

  <Footer lang={lang} />
</body>
</html>